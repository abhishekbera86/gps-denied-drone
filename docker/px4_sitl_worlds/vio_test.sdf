      <pose>-3.694 -4.750 0.575 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.45 0.45 1.15</size></box></geometry>
          <material><ambient>0.1 0.9 0.1 1</ambient><diffuse>0.1 0.9 0.1 1</diffuse></material>
