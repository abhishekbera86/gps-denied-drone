<?xml version="1.0" encoding="UTF-8"?>
<!--
  vio_test.sdf — textured/prop-scattered world for Phase 3 Milestone B
  (real OpenVINS monocular VIO) development and testing.

  Same repo-owned overlay mechanism as empty.sdf (copied into PX4's
  Tools/simulation/gz/worlds/ at Docker build time — never a fork of
  upstream). Select it at runtime with PX4_GZ_WORLD=vio_test (see
  resource/phase3-gps-denied-localization-source.md, "Milestone B
  implementation findings").

  WHY THIS WORLD EXISTS: monocular VIO (OpenVINS) needs corner features to
  track — confirmed live that empty.sdf's flat, untextured 500x500 gray
  ground plane gives the feature tracker zero usable corners, so
  OpenVINS's initializer fails every single frame
  ("[init]: failed initialization in 0.0000 seconds", instantly, forever —
  not a slow convergence, a hard block). This world adds a rectangular
  "fence" of static, brightly-colored boxes CENTERED ON THE ORIGIN — the
  vehicle spawns at the origin, missions take off and land there, and the
  centered square_mission (3m side, corners ±1.5m) flies well inside the
  fence with ≥3.25m margin (see the props' own comment below for exact
  placement/why), all sized to stay within the front-facing D435i's view
  at the 2m takeoff/cruise altitude. GPS missions are unaffected by this
  world (props are outside the flight paths, not obstacles on them).

  IMPORTANT: the <world name="..."> below MUST equal the PX4_GZ_WORLD value
  ("vio_test"). PX4's gz_bridge builds every Gazebo topic as
  /world/<world_name>/... — a name mismatch means the bridge subscribes to
  the wrong topics and no sim data flows.

  Physics/scene/light/spherical_coordinates are identical to empty.sdf —
  only the added prop models differ.
-->
<sdf version="1.9">
  <world name="vio_test">
    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>
    <scene>
      <grid>true</grid>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
    </scene>
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>1 1</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode/>
            </friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>500 500</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
        <pose>0 0 0 0 -0 0</pose>
        <inertial>
          <pose>0 0 0 0 -0 0</pose>
          <mass>1</mass>
          <inertia>
            <ixx>1</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>1</iyy>
            <iyz>0</iyz>
            <izz>1</izz>
          </inertia>
        </inertial>
        <enable_wind>false</enable_wind>
      </link>
      <pose>0 0 0 0 -0 0</pose>
      <self_collide>false</self_collide>
    </model>
    <light name="sunUTC" type="directional">
      <pose>0 0 500 0 -0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1</intensity>
      <direction>0.001 0.625 -0.78</direction>
      <diffuse>0.904 0.904 0.904 1</diffuse>
      <specular>0.271 0.271 0.271 1</specular>
      <attenuation>
        <range>2000</range>
        <linear>0</linear>
        <constant>1</constant>
        <quadratic>0</quadratic>
      </attenuation>
      <spot>
        <inner_angle>0</inner_angle>
        <outer_angle>0</outer_angle>
        <falloff>0</falloff>
      </spot>
    </light>
    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>47.397971057728974</latitude_deg>
      <longitude_deg> 8.546163739800146</longitude_deg>
      <elevation>0</elevation>
    </spherical_coordinates>

    <!-- Feature-rich static props: a rectangular "fence" of colored boxes,
         CENTERED ON THE WORLD ORIGIN (recentered 2026-07-13 — see below).
         The vehicle spawns at the origin, so the origin is also where
         PX4's local/odom frame initializes and where every mission takes
         off and lands. The fence spans x,y in [-4.75, 4.75]; the centered
         square_mission (3m side -> corners at ±1.5m, see sim_params.yaml
         and square_mission.py) keeps ≥3.25m of margin from any prop at
         every corner, and the landing point (the origin) sits a full
         4.75m from the nearest prop in every direction.

         WHY RECENTERED: the original layout put the fence around the OLD
         first-quadrant mission footprint (x,y in [-1.5, 8]), which left
         the spawn/landing point only 1.5m from TWO fence lines — with
         mono-VIO's known stochastic estimate drift, user-observed flights
         drifted into the props during landing. Same props, sizes, colors,
         and ~1.1m spacing as before (chosen so the front-facing camera's
         ~69 deg horizontal FOV reliably has several in view on every leg,
         at any heading; heights/sizes/colors vary for FAST-corner
         richness) — a pure translation by (-3.25, -3.25). Earlier attempt
         (a sparse 12-box ring at 4-8m radius) left most of the frame's
         5x5 detection grid cells empty, and OpenVINS's KLT tracker found
         only ~5 corners total and RANSAC rejected them on the very next
         frame ("Failed to get enough points to do RANSAC, resetting....."),
         so the feature database stayed empty and initialization failed
         every frame. See resource/phase3-gps-denied-localization-source.md. -->

    <model name="vio_fence_000">
      <static>true</static>
      <pose>-4.750 -4.750 0.350 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.3 0.3 0.7</size></box></geometry>
          <material><ambient>0.9 0.1 0.1 1</ambient><diffuse>0.9 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="collision">
          <geometry><box><size>0.3 0.3 0.7</size></box></geometry>
        </collision>
      </link>
    </model>
