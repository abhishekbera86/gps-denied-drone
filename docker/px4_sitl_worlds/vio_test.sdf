    <!-- TEXTURED GROUND PAD (2026-07-10) — replaces the 64 solid-color 1m
         "vio_floor_tile" boxes AND the 64 0.25m "vio_pad_tile" boxes that
         previously lived here (128 entities -> 1). Solid-color tiles only
         ever produce trackable corners at 3-color junctions, and with the
         camera mount now pitched 30deg down, the ground-level view spans
         just ~0.2-1.5m ahead — at that range even 0.25m tiles fill
         hundreds of pixels each, leaving a real captured frame with only
         5-7 FAST corners at the estimator's threshold of 30 (measured
         with cv2 on actual frames, with AND without shadows), below
         OpenVINS's hard 15-feature initializer minimum, so VIO could
         never initialize. The fix is a real image texture with detail at
         MULTIPLE scales: textures/vio_ground_mosaic.png, a seeded
         reproducible non-periodic mosaic (64/16/4px nested cells ≈
         26cm/6.5cm/1.6cm on the ground at 2048px over 8m — corners at
         every viewing distance from ground-level init to 2m cruise, no
         checkerboard aliasing). Generated by
         textures/generate_vio_ground_mosaic.py (checked in, seeded).
         Baked into the px4-sim image by Dockerfile.px4_sim alongside this
         world file; the albedo_map path below is the ABSOLUTE in-image
         path. The 3x3m vio_ring_tile_* boxes beyond this pad and the
         fence props are unchanged (mid-field/cruise features). -->
    <model name="vio_ground_tex">
      <static>true</static>
      <pose>2.0 2.0 0.005 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>8.0 8.0 0.01</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
            <pbr>
              <metal>
                <albedo_map>/PX4-Autopilot/Tools/simulation/gz/worlds/textures/vio_ground_mosaic.png</albedo_map>
                <roughness>0.9</roughness>
                <metalness>0.0</metalness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
