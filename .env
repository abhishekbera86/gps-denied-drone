# =============================================================
# .env — Shared Environment Variables
# =============================================================
# All version pins and runtime settings live here.
# Edit this file to upgrade versions across the entire stack.
# Do NOT commit secrets or personal credentials here.
# =============================================================

# ── Version Pins ──────────────────────────────────────────────
# These versions must stay in sync:
#   PX4_VERSION and PX4_MSGS_TAG must match the same release.
#   If you upgrade PX4, update BOTH.
PX4_VERSION=v1.14.3
PX4_MSGS_TAG=release/1.14
ROS_DISTRO=humble
REALSENSE_SDK_VERSION=v2.55.1
OPENVINS_BRANCH=master

# ── Display (X11 forwarding for Gazebo GUI) ───────────────────
# Run: xhost +local:docker   before starting containers
# If using HEADLESS=1 below, this is not needed for simulation.
DISPLAY=:0

# ── Simulation Settings ───────────────────────────────────────
# PX4_HEADLESS=1     : Disable Gazebo GUI window.
#                      REQUIRED on machines without GPU (e.g. ThinkPad W541).
#                      Saves ~40% CPU — always leave this on unless debugging visuals.
PX4_HEADLESS=1

# PX4_SIM_SPEED_FACTOR: Run simulation at fraction of real-time.
#   1.0 = real-time (requires fast machine with GPU)
#   0.5 = half speed (recommended for CPU-only machines)
#   Lower values prevent EKF2 from failing due to timing on slow CPUs.
PX4_SIM_SPEED_FACTOR=0.5

# PX4 Gazebo model to simulate
PX4_GZ_MODEL=x500

# ── Networking ────────────────────────────────────────────────
# All containers use network_mode: host — no port mapping needed.
# uXRCE-DDS Agent listens on this UDP port.
UXRCE_DDS_PORT=8888

# MAVLink ports (for QGroundControl connection)
MAVLINK_GCS_PORT=14550
MAVLINK_OFFBOARD_PORT=14540

# ── ROS2 Middleware ───────────────────────────────────────────
# CycloneDDS is most reliable with PX4 on network_mode:host.
# Do not change unless you know what you are doing.
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# ── Hardware (Phase 5 — Orange Pi + Pixhawk) ─────────────────
# Serial port connecting Orange Pi to Pixhawk (via UART or USB)
PIXHAWK_SERIAL_PORT=/dev/ttyUSB0
PIXHAWK_BAUD_RATE=921600
