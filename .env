# =============================================================================
# .env — Shared environment variables for the quad-drone project
# =============================================================================
# Edit this file to upgrade versions. docker-compose.yml passes these through
# as build args / runtime env. Do NOT commit secrets or credentials.
# =============================================================================

# ── Version Pins ──────────────────────────────────────────────────────────
# PX4 firmware version — must match the px4_msgs/px4_ros_com branches below.
# Flash this SAME version to the physical Pixhawk 6 in Phase 4.
PX4_VERSION=v1.17.0
PX4_MSGS_BRANCH=release/1.17
PX4_ROS_COM_BRANCH=release/1.16

# ROS 2 distribution
ROS_DISTRO=humble

# Gazebo vehicle model for SITL (x500_depth = x500 quad + simulated depth
# camera, so OpenVINS has something to consume once Phase 3 wires up VIO).
PX4_GZ_MODEL=x500_depth

# Gazebo world for SITL — NOT set here on purpose. This is a per-invocation
# runtime choice (`PX4_GZ_WORLD=empty|vio_test make sim-gui`), not a build-
# time constant like the versions above — the Makefile's own
# `PX4_GZ_WORLD ?= empty` supplies the default. Setting it here would
# silently WIN over a shell-exported override (`include .env` + `export`
# in the Makefile makes a plain `=` assignment here beat a same-named
# environment variable, regardless of the Makefile's own `?=` default) —
# this was a real, confirmed bug: `PX4_GZ_WORLD=vio_test make sim-gui`
# silently ran the `empty` world anyway until this line was removed. `empty`
# = repo-owned bare world (docker/px4_sitl_worlds/empty.sdf); `vio_test` =
# textured/prop-scattered world Milestone B (real OpenVINS VIO) needs
# (docker/px4_sitl_worlds/vio_test.sdf). Any world bundled by PX4 also works
# by name (default, walls, baylands, …).

# ── Simulation Flags ──────────────────────────────────────────────────────
# HEADLESS: 1 = Gazebo runs with no GUI window (default; fast, no display
# needed). For the GUI, don't change this — use `make sim-gui`, which layers
# docker-compose.gui.yml to set HEADLESS=0 and forward the host X display.
# (The dev host — a ThinkPad W541 — does have a usable GPU: Intel HD 4600
# iGPU via Mesa renders the Gazebo GUI fine. Headless stays the default only
# because it's faster and works with no display, e.g. over SSH / in CI.)
PX4_HEADLESS=1

# ── Networking ────────────────────────────────────────────────────────────
# Both containers use network_mode: host, so 127.0.0.1 is shared between
# them — no explicit port mapping needed.
# Micro-XRCE-DDS Agent port (UDP, PX4 <-> ROS 2). NO inline comments here:
# docker compose strips the comment but keeps the padding whitespace in the
# value, and MicroXRCEAgent rejects the padded port and exits at boot.
UXRCE_DDS_PORT=8888

# ── ROS 2 / DDS Middleware ────────────────────────────────────────────────
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
DRONE_NAMESPACE=drone1

# ── Hardware — Orange Pi 5 Plus + Pixhawk 6 (wired up in Phase 4) ────────
# librealsense SDK version — MUST match physical D435i firmware.
LIBREALSENSE_VERSION=2.58.2
PIXHAWK_SERIAL_PORT=/dev/ttyUSB0
PIXHAWK_BAUD_RATE=921600
