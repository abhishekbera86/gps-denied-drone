# =============================================================================
# .env — Shared environment variables for the quad-drone project
# =============================================================================
# Edit this file to upgrade versions. All Dockerfiles and docker-compose
# read variables from here.  Do NOT commit secrets or credentials.
# =============================================================================

# ── Version Pins ──────────────────────────────────────────────────────────
# PX4 firmware version — must match px4_msgs branch below.
PX4_VERSION=v1.14.3

# Aerostack2 image tag (nightly-humble = latest ROS 2 Humble nightly build)
AS2_IMAGE_TAG=nightly-humble

# librealsense SDK version — MUST match physical D435i firmware 5.17.3.10
LIBREALSENSE_VERSION=2.58.2

# ROS 2 distribution
ROS_DISTRO=humble

# Gazebo model for SITL (x500 = standard quadcopter with depth camera mount)
PX4_GZ_MODEL=x500

# ── Simulation Flags ──────────────────────────────────────────────────────
# HEADLESS: 1 = no Gazebo GUI window (REQUIRED — no GPU on this host)
PX4_HEADLESS=1

# Sim speed factor: 0.5 = half realtime (prevents EKF2 timing failures
# on CPU-only machines without hardware clock acceleration)
PX4_SIM_SPEED_FACTOR=0.5

# ── Networking ────────────────────────────────────────────────────────────
# All containers use network_mode: host.
# Ports listed here for documentation only — no explicit mapping needed.
UXRCE_DDS_PORT=8888          # MicroXRCE-DDS Agent (UDP, PX4 ↔ ROS 2)
MAVLINK_GCS_PORT=14550        # QGroundControl telemetry
MAVLINK_OFFBOARD_PORT=14540   # Offboard setpoint port

# ── ROS 2 / DDS Middleware ────────────────────────────────────────────────
# CycloneDDS is the most reliable with PX4 on network_mode: host.
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# ── Hardware — Orange Pi 5 + Pixhawk ─────────────────────────────────────
# Serial port connecting companion computer to Pixhawk flight controller.
# Verify with: ls -la /dev/serial/by-id/ inside the hw container.
PIXHAWK_SERIAL_PORT=/dev/ttyUSB0
PIXHAWK_BAUD_RATE=921600
